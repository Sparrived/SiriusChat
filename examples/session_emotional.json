{
  "//": "Sirius Chat Emotional Engine 配置示例 (v0.28+)",
  "// 说明": "此配置用于 EmotionalGroupChatEngine，与 legacy SessionConfig 不兼容。",
  "// 入口": "python main.py --config this_file.json --engine emotional",

  "providers": [
    {
      "type": "openai-compatible",
      "base_url": "https://api.openai.com",
      "api_key": "${OPENAI_API_KEY}",
      "healthcheck_model": "gpt-4o-mini"
    }
  ],

  "persona": "warm_friend",
  "// persona": "可选值：warm_friend | sarcastic_techie | gentle_caregiver | chaotic_jester | stoic_observer | protective_elder | generated（从 roleplay 资产加载）",

  "emotional_engine": {
    "// 感知层": "",
    "working_memory_max_size": 20,

    "// 认知层": "",
    "enable_semantic_retrieval": false,
    "sensitivity": 0.5,
    "task_model_overrides": {
      "// 示例": { "model": "gpt-4o-mini", "max_tokens": 256, "temperature": 0.7 },
      "response_generate": { "model": "gpt-4o", "max_tokens": 512, "temperature": 0.7 },
      "emotion_analyze": { "model": "gpt-4o-mini", "max_tokens": 256, "temperature": 0.2 },
      "intent_analyze": { "model": "gpt-4o-mini", "max_tokens": 256, "temperature": 0.2 },
      "cognition_analyze": { "model": "gpt-4o-mini", "max_tokens": 384, "temperature": 0.2 }
    },

    "// 决策层": "",
    "// sensitivity": "回复敏感度（0.0~1.0）。越高越容易回复。",

    "// 执行层 - 延迟回复": "",
    "delayed_queue_tick_interval_seconds": 10,

    "// 执行层 - 主动发言": "",
    "proactive_silence_minutes": 30,
    "proactive_check_interval_seconds": 60,

    "// 后台任务 - 记忆晋升": "",
    "memory_promote_interval_seconds": 300,
    "working_memory_promote_threshold": 0.3,

    "// 后台任务 - 语义整合": "",
    "consolidation_interval_seconds": 600
  }
}
