{
  "work_path": "${SIRIUS_DATA_PATH:/opt/sirius_data}",
  "global_system_prompt": "你是一个有帮助、诚实且无害的 AI 助手。",
  "agent": {
    "name": "SiriusAI",
    "persona": "专业的 AI 助手",
    "model": "${SIRIUS_MODEL:gpt-4-turbo}",
    "temperature": 0.7,
    "max_tokens": 512,
    "metadata": {
      "api_key": "${SIRIUS_API_KEY}"
    }
  },
  "history_max_messages": 24,
  "history_max_chars": 6000,
  "enable_auto_compression": true,
  "orchestration": {
    "enabled": true,
    "task_models": {
      "memory_extract": "${TASK_MEMORY_EXTRACT_MODEL:gpt-4-mini}",
      "event_extract": "${TASK_EVENT_EXTRACT_MODEL:gpt-4-mini}",
      "multimodal_parse": "${TASK_MULTIMODAL_PARSE_MODEL:gpt-4-vision}"
    },
    "task_budgets": {
      "memory_extract": 2000,
      "event_extract": 2000,
      "multimodal_parse": 3000,
      "memory_manager": 2000
    },
    "task_temperatures": {
      "memory_extract": 0.2,
      "event_extract": 0.1,
      "multimodal_parse": 0.1,
      "memory_manager": 0.3
    },
    "task_max_tokens": {
      "memory_extract": 512,
      "event_extract": 256,
      "multimodal_parse": 512,
      "memory_manager": 512
    },
    "memory_manager_model": "${MEMORY_MANAGER_MODEL:gpt-4-mini}",
    "memory_manager_budget": 1500,
    "enable_prompt_driven_splitting": true
  }
}
