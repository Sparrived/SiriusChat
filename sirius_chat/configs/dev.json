{
  "work_path": "./sirius_data_dev",
  "global_system_prompt": "你是一个有帮助、诚实且无害的 AI 助手。（开发环境）",
  "agent": {
    "name": "SiriusAI-Dev",
    "persona": "热心、专业的 AI 助手（开发环境测试）",
    "model": "gpt-4-turbo",
    "temperature": 0.9,
    "max_tokens": 1024,
    "metadata": {
      "alias": "开发助手"
    }
  },
  "history_max_messages": 32,
  "enable_auto_compression": false,
  "orchestration": {
    "task_enabled": {
      "memory_extract": true,
      "event_extract": true,
      "memory_manager": true
    },
    "task_models": {
      "memory_extract": "gpt-4-mini",
      "event_extract": "gpt-4-mini",
      "memory_manager": "gpt-4-mini"
    },
    "task_temperatures": {
      "memory_extract": 0.2,
      "event_extract": 0.1,
      "memory_manager": 0.3
    },
    "task_max_tokens": {
      "memory_extract": 512,
      "event_extract": 256,
      "memory_manager": 512
    },
    "enable_prompt_driven_splitting": true
  }
}
